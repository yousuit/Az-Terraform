# Terraform state files — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directories
**/.terraform/
**/.terraform.lock.hcl

# Variable files that may contain secrets — use -var flags instead
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# Sensitive values files (add specific ones if needed)
# secrets.tfvars

# macOS
.DS_Store

# Editor directories
.idea/
.vscode/
*.swp
*.swo
